# Database Configuration
# Local SQLite default (auto-created): sqlite:///./disaster_response.db
# Production PostgreSQL example: postgresql://user:password@localhost:5432/rescueai
DATABASE_URL=sqlite:///./disaster_response.db

# Authentication
JWT_SECRET=supersecretjwtkeyreplaceinproduction123!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# AI Provider API Keys
GEMINI_API_KEY=
OPENWEATHER_API_KEY=
TAVILY_API_KEY=

# Backend URL for Frontend Communication
BACKEND_URL=http://localhost:8000

# App Environment (development / production)
ENVIRONMENT=development
